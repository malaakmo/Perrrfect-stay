<Window x:Class="Perrrfect_stay.SitterProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Perrrfect_stay"
        mc:Ignorable="d"
        Title="SitterProfileWindow" Height="450" Width="800">
    <Grid Background="#F8F4F2">
        <Border Width="500" Height="480" Padding="40"
            Background="White" CornerRadius="20"
            VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="&lt; Back" Cursor="Hand"
                       Foreground="#E8A87C" FontWeight="Bold"
                       Margin="0,0,0,20"/>
                <TextBlock Text="🐾" FontSize="60"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
                <TextBlock x:Name="SitterName" FontSize="24" FontWeight="Bold"
                       Foreground="#5A4634" HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>
                <TextBlock x:Name="SitterPrice" FontSize="16"
                       Foreground="#E8A87C" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
                <TextBlock x:Name="SitterLocation" FontSize="14"
                       Foreground="#7A6A58"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
                <TextBlock x:Name="SitterBio" FontSize="14"
                       Foreground="#7A6A58"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>
                <Button Content="Book Sitter 🐾"
                    Click="BookSitter_Click"
                    Height="45" Background="#E8A87C"
                    Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

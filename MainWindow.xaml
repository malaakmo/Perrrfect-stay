<Window x:Class="Perrrfect_stay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Perrrfect_stay"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Grid Margin="0,0,0,0" >
        <Border Width = "543"
                Height="547"
                Padding = "40"
                Background="#FFF0ED"
                CornerRadius="25"
                VerticalAlignment="Center"
                
                HorizontalAlignment="Left" Margin="196,0,0,0" >

            <StackPanel>
                <TextBlock Text=""
                         FontSize="40"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,10"/>

                <TextBlock Text =" Perrrfect Stay  🐾"
                       FontSize =" 32"
                       FontWeight ="Bold"
                           Foreground="#5A4634"
                       HorizontalAlignment =" Center"
                       Margin = "0,0,0,5"/>

                <TextBlock  Text="Welcome Back!"
                       FontSize=" 18"
                       Foreground="#7A6A58"     
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25" />
                <TextBlock Text="Email:" />
                <TextBox x:Name ="EmailBox"
                    Height="38"
                         Background="#FFF3E8"
                         BorderBrush="#E8A87C"
                         BorderThickness="1"
                         Padding="10"
                     Margin="0,5,0,15" />
                <TextBlock Text="Password :"/>
                <PasswordBox x:Name ="PasswordBox"
                    Height="38"
                             Background="#FFF3E8"
                             BorderBrush="#E8A87C"
                             BorderThickness="1"
                             Padding="10"
                          
                             
                         Margin="0,5,0,20"/>
                <Button Content="Login"
                        Click="Login_Click"
                   Height="40"
                   Background="#E8A87C"
                   Foreground="White"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

                <Button Content="Create Account"
                Height="40"  Click="CreateAccount_Click"/>
                <TextBlock Text="Forgot Password?"
                           Foreground="#E8A87C"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           Cursor="Hand"
                           MouseLeftButtonDown="ForgotPassword_Click"
                           Margin="0,0,0,10"/>




            </StackPanel>
        </Border>

    </Grid>
</Window>

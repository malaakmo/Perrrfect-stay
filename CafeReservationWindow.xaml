<Window x:Class="Perrrfect_stay.CafeReservationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Perrrfect_stay"
        mc:Ignorable="d"
        Title="CafeReservationWindow" Height="450" Width="800">
    <Grid>
        <Border Width="500 " Height="450" Padding="40"
                Background="#FFF0ED" CornerRadius="25"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>



                <TextBlock Text="&lt; Back" Cursor="Hand"
                           Foreground="#E8A87C" FontWeight="Bold"
                           Margin="0,0,0,20"/>


                <TextBlock Text="Reserve a Table 🐾"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#5A4634" HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text ="Table"/>
                <ComboBox x:Name="TableCombo" Height="38"
                          Margin="0,5,0,15"/>

                <TextBlock Text="Time Slot:"/>
                <ComboBox x:Name="TimeSlotCombo" Height="38" Margin="0,5,0,15"/>

                <TextBlock Text="Number of people:"/>
                <TextBox x:Name="PeopleBox" Height="38" Background="#FFF3E8"
          BorderBrush="#E8A87C" Padding="10" Margin="0,5,0,25" />

                <Button Content="Reserve Table" Click="ReserveTable_Click" Height="40"
            Background="#E8A87C" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
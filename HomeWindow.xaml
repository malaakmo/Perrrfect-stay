<Window x:Class="Perrrfect_stay.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Perrrfect_stay"
        mc:Ignorable="d"
        Title="Home" Height="800" Width="450"
                WindowStartupLocation="CenterScreen"
                Background="#F8F4F2" 
                  FontFamily ="Georgia">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />

            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,10,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="White"
                        CornerRadius="8"
                        Padding="12, 6">
                    <TextBlock Text="LOGO"
                               FontWeight="Bold"
                               FontSize="18"
                               Foreground="#6B4A3A"/>

                </Border>

                <TextBlock Grid.Column="1"
                           Text="🔔"
                           FontSize="24"
                           Margin="20,0"
                           Cursor="Hand"
                           MouseLeftButtonDown="Messages_Click"/>

                <TextBlock Grid.Column="2"
                           Text="👤"
                           FontSize="24"
                           Margin="20,0"
                           Cursor="Hand"
                           MouseLeftButtonDown="Profile_Click"/>

                <TextBlock Grid.Column="3"
                           Text="☰"
                           FontSize="24"
                           Margin="20,0"/>
            </Grid>

            <Border Grid.Row="1"
                   Height="180"
                   Background="#EADDD7"
                   CornerRadius="20"
                   Margin="0,0,0,30"
                    >
                <TextBlock Text="BANNER IMAGE"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#8B5E3C"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

            </Border>
            <UniformGrid Grid.Row="3"
                         Columns="3"
                         Rows="1"
                         HorizontalAlignment="Stretch">

                <Button Grid.Row="2"
                    Content="Adopt a Cat"
                    Height="55"
                    FontFamily="Georgia"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Background="White"
                    Foreground="#8B5E3C"
                    BorderBrush="#D6B8A5"
                    BorderThickness="2"
                    Margin="40,0,40,40"
                        Click="AdoptCat_Click"/>

            <Button Margin="5"
                    Height="160"
                    Background="White"
                    BorderBrush="#E0D5CF"
                    BorderThickness="1"
                    Click="CatHotel_Click">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🏨"
                               FontSize="40"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Cat Hotel"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,5" />
                    <TextBlock Text="Book Now"
                               FontSize="12"
                               HorizontalAlignment="Center"/>


                </StackPanel>
            </Button>
            <Button Margin="5"
                              Height="160"
                              Background="White"
                              BorderBrush="#E0D5CF"
                              BorderThickness="1"
                               Click="CatCafe_Click">

                    <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="☕"
                FontSize="40"
                HorizontalAlignment="Center"/>
                    <TextBlock Text="Cat Cafe"
                FontSize="16"
                FontWeight="Bold"
                HorizontalAlignment="Center"
                Margin="0,10,0,5" />
                    <TextBlock Text="Reserve"
                FontSize="12"
                HorizontalAlignment="Center"/>

                </StackPanel>
            </Button>

                <Button Margin="5"
                  Height="160"
                  Background="White"
                  BorderBrush="#E0D5CF"
                  BorderThickness="1"
                      Click="Sitting_Click"  >


                    <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🐾"
                               FontSize="40"
                                HorizontalAlignment="Center"/>
                      <TextBlock Text="Sitting"
                                 FontSize="16"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  Margin="0,10,0,5" />
                    <TextBlock Text="Find"
                               FontSize="12"
                               HorizontalAlignment="Center"/>

                </StackPanel>
            </Button>
            </UniformGrid>

        </Grid>
    </ScrollViewer>
   
</Window>

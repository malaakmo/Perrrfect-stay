<Window x:Class="Perrrfect_stay.SponsorCatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Perrrfect_stay"
        mc:Ignorable="d"
        Title="SponsorCatWindow" Height="450" Width="800">
    <Grid>
        <Border Width="500 " Height="450" Padding="40"
         Background="#FFF0ED" CornerRadius="20"
         VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>



                <TextBlock Text="Select  Cat 🐾" />
                <ComboBox x:Name="CatCombo" Height="38"
                                  Margin="0,5,0,15"/>

                <TextBlock Text="Monthly Amount (€):"/>
                <TextBox x:Name="AmountBox" Height="38" Background="#FFF3E8"                 
                 BorderBrush="#E8A87C" Padding="10" Margin="0,5,0,20" />


                <Button Content="Sponsor! 🐱" Click="Sponsor_Click" Height="45"
                        Background="#E8A87C" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>

                <Button Content="&lt; Back" Click="Back_Click" Height="35"
                         Background="#7A6A58" Foreground="White" />


            </StackPanel>
        </Border>
    </Grid>
</Window>

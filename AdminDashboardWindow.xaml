<Window x:Class="Perrrfect_stay.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Perrrfect_stay"
        mc:Ignorable="d"
        Title="AdminDashboardWindow" Height="450" Width="800">
    <Grid Background="#F8F4F2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20" Background="#5A4634">
            <TextBlock Text="Admin Dashboard" FontSize="28" FontWeight="Bold"
                 Foreground="White" 
                   HorizontalAlignment="Center"/>

        </Border>

        <StackPanel Grid.Row="1"  Margin="40" VerticalAlignment="Center">


            <Button Content="👥 Manage Users" 
                    Click="ManageUsers_Click" 
                    Height="60" FontSize="18" FontWeight="Bold"
                    Background="#E8A87C" Foreground="White" Margin="0,0,0,15"/>



            <Button Content="📋 Pending Requests" 
                    Click="PendingRequests_Click" 
                    Height="60" FontSize="18" FontWeight="Bold"
                    Background="#E8A87C" Foreground="White" Margin="0,0,0,15"/>



            <Button Content="👥 Manage Cats" 
                    Click="ManageCats_Click" 
                    Height="60" FontSize="18" FontWeight="Bold"
                    Background="#E8A87C" Foreground="White" Margin="0,0,0,15"/>



            <Button Content="🚪 Logout" 
                    Click="Logout_Click" 
                    Height="60" FontSize="18" FontWeight="Bold"
                    Background="#E8A87C" Foreground="White" Margin="0,0,0,15"/>
        </StackPanel>

    </Grid>
    
</Window>

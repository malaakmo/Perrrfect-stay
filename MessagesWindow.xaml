<Window x:Class="Perrrfect_stay.MessagesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Perrrfect_stay"
        mc:Ignorable="d"
        Title="MessagesWindow" Height="450" Width="800">

    <Grid Background="#F8F4F2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <Border Grid.Column="0" Background="White" BorderBrush="#E8A87C" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#5A4634" Padding="15">
                    <TextBlock Text="Chats 💬" FontSize="18" FontWeight="Bold"
                           Foreground="White"/>
                </Border>
                <ListBox Grid.Row="1" x:Name="ChatList"
                     SelectionChanged="ChatList_SelectionChanged"
                     Background="Transparent" BorderThickness="0"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#5A4634" Padding="15">
                <TextBlock x:Name="ConversationTitle" Text="Select a chat"
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
            </Border>

            <ScrollViewer Grid.Row="1" x:Name="MessagesScroll" Margin="10">
                <StackPanel x:Name="MessagesPanel"/>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="MsgBox"
                     Height="38" Padding="10"
                     Background="#FFF3E8" BorderBrush="#E8A87C"/>
                <Button Grid.Column="1" Content="Send"
                    Click="Send_Click"
                    Margin="5,0,0,0" Padding="15,0"
                    Background="#E8A87C" Foreground="White"
                    FontWeight="Bold" Height="38"/>
            </Grid>
        </Grid>

    </Grid>
</Window>
